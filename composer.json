{
    "name": "jandres25/php-mvc-admin-starter",
    "description": "PHP MVC admin starter with authentication, user management and permission-based access control",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "phpmailer/phpmailer": "^6.9",
        "tecnickcom/tcpdf": "^6.7",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": { "App\\": "app/" },
        "files": ["app/Core/helpers.php"]
    },
    "autoload-dev": {
        "psr-4": { "Tests\\": "tests/" }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite=Unit",
        "test:integration": "phpunit --testsuite=Integration"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}